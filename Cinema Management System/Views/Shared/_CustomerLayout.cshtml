<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>@ViewData["Title"] - Cinema Admin</title>
    
    <link href="https://cdn.jsdelivr.net/npm/simple-datatables@7.1.2/dist/style.min.css" rel="stylesheet" />
    <link href="~/css/admin/styles.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css">
    
    <style>
        .sb-nav-link-icon { font-size: 1.1rem; width: 1.5rem; text-align: center; margin-right: 0.5rem; }
        .navbar-brand { font-weight: 700; letter-spacing: 0.5px; }
        .nav-link.active { color: #fff !important; background-color: rgba(255,255,255,0.1); border-radius: 4px; }
    </style>

    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>
</head>
<body class="sb-nav-fixed">
    
    <nav class="sb-topnav navbar navbar-expand navbar-dark bg-dark shadow">
        <a class="navbar-brand ps-3" href="/Admin/Home">
            <i class="bi bi-camera-reels me-2"></i>Cinema Admin
        </a>
        <button class="btn btn-link btn-sm order-1 order-lg-0 me-4 me-lg-0" id="sidebarToggle"><i class="fas fa-bars"></i></button>
        
        <form class="d-none d-md-inline-block form-inline ms-auto me-0 me-md-3 my-2 my-md-0">
            <div class="input-group">
                <input class="form-control border-0 bg-secondary bg-opacity-25 text-white" type="text" placeholder="Quick search..." aria-label="Search" />
                <button class="btn btn-primary" type="button"><i class="fas fa-search"></i></button>
            </div>
        </form>

        <ul class="navbar-nav ms-auto ms-md-0 me-3 me-lg-4">
            <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle d-flex align-items-center" id="navbarDropdown" href="#" role="button" data-bs-toggle="dropdown">
                    <img src="https://ui-avatars.com/api/?name=Admin&background=0D6EFD&color=fff" class="rounded-circle me-2" width="25" alt="Avatar">
                    <span class="d-none d-md-inline">Admin User</span>
                </a>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="navbarDropdown">
                    @if (User.Identity.IsAuthenticated)
                        {
                            <li><a class="dropdown-item" href="/Identity/Profile/Index" ><i class="bi bi-person me-2"></i>Profile</a></li>
                            <li><a class="dropdown-item" href="#!"><i class="bi bi-gear me-2"></i>Settings</a></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li><a class="dropdown-item text-danger"asp-area ="Identity" asp-controller ="Account"  asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                        }
                        else
                        {
                            <li><a asp-area ="Identity" asp-controller ="Account"  asp-action="Login" class="dropdown-item"><i class="bi bi-gear me-2"></i>Login</a></li>
                        }

                </ul>
            </li>
        </ul>
    </nav>

    <div id="layoutSidenav">
        <div id="layoutSidenav_nav">
            <nav class="sb-sidenav accordion sb-sidenav-dark shadow-sm" id="sidenavAccordion">
                <div class="sb-sidenav-menu">
                    <div class="nav">
                        <div class="sb-sidenav-menu-heading">Insights</div>
                        <a class="nav-link" href="/Admin/Home">
                            <div class="sb-nav-link-icon"><i class="bi bi-speedometer2"></i></div>
                            Dashboard
                        </a>

                        <div class="sb-sidenav-menu-heading">Catalog Management</div>
                        
                        <a class="nav-link collapsed" href="#" data-bs-toggle="collapse" data-bs-target="#collapseEntities">
                            <div class="sb-nav-link-icon"><i class="bi bi-collection-play"></i></div>
                            Movie Data
                            <div class="sb-sidenav-collapse-arrow"><i class="fas fa-angle-down"></i></div>
                        </a>
                        <div class="collapse show" id="collapseEntities" data-bs-parent="#sidenavAccordion">
                            <nav class="sb-sidenav-menu-nested nav">
                                <a class="nav-link" href="/Admin/Movie/Index"><i class="bi bi-film me-2"></i>Movies</a>
                                <a class="nav-link" href="/Admin/Cinema/Index"><i class="bi bi-building me-2"></i>Cinemas</a>
                                <a class="nav-link" href="/Admin/Category"><i class="bi bi-tags me-2"></i>Categories</a>
                                <a class="nav-link" href="/Admin/Actor"><i class="bi bi-people me-2"></i>Actors</a>
                            </nav>
                        </div>

                        <div class="sb-sidenav-menu-heading">Sales & Ops</div>
                        <a class="nav-link" href="/Admin/Order">
                            <div class="sb-nav-link-icon"><i class="bi bi-cart-check"></i></div>
                            Orders
                        </a>
                        <a class="nav-link" href="/Admin/Ticket">
                            <div class="sb-nav-link-icon"><i class="bi bi-ticket-perforated"></i></div>
                            Tickets
                        </a>
                        <a class="nav-link" href="/Admin/User">
                            <div class="sb-nav-link-icon"><i class="bi bi-person-badge"></i></div>
                            Users
                        </a>
                        <a class="nav-link" href="/Admin/Slider">
                            <div class="sb-nav-link-icon"><i class="bi bi-images"></i></div>
                            Web Banners
                        </a>

                        <div class="sb-sidenav-menu-heading">System</div>
                        <a class="nav-link" href="charts.html">
                            <div class="sb-nav-link-icon"><i class="fas fa-chart-area"></i></div>
                            Reports
                        </a>
                    </div>
                </div>
                <div class="sb-sidenav-footer">
                    <div class="small">System Status:</div>
                    <span class="badge bg-success">Online</span>
                </div>
            </nav>
        </div>

        <div id="layoutSidenav_content">
            <main>
                @RenderBody()
            </main>
            
            <footer class="py-4 bg-light mt-auto border-top">
                <div class="container-fluid px-4">
                    <div class="d-flex align-items-center justify-content-between small">
                        <div class="text-muted">Copyright &copy; CinemaPro Admin @DateTime.Now.Year</div>
                        <div>
                            <a href="#" class="text-decoration-none text-muted me-3">Privacy Policy</a>
                            <a href="#" class="text-decoration-none text-muted">Terms</a>
                        </div>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script src="~/js/admin/scripts.js"></script>
    
    <script src="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // Auto-highlight active sidebar links
        $(document).ready(function() {
            var path = window.location.pathname;
            $('.sb-sidenav .nav-link').each(function() {
                if (this.pathname === path) {
                    $(this).addClass('active');
                    $(this).closest('.collapse').addClass('show');
                }
            });
        });
    </script>
    @RenderSection("Scripts", false)
</body>
</html>