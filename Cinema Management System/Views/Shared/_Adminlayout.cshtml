<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Media Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root { --sidebar-bg: #212529; --main-bg: #f3f3f9; }
        body { background-color: var(--main-bg); font-family: 'Inter', sans-serif; }
        .wrapper { display: flex; }
        #sidebar { width: 250px; height: 100vh; background: var(--sidebar-bg); position: fixed; color: #abb9e8; transition: 0.3s; z-index: 1000; }
        #content { margin-left: 250px; width: 100%; min-height: 100vh; }
        .nav-link { color: #abb9e8; padding: 12px 20px; font-size: 0.9rem; }
        .nav-link:hover, .nav-link.active { color: #fff; background: rgba(255,255,255,0.1); }
        .nav-title { font-size: 0.7rem; font-weight: bold; color: #5d6681; padding: 20px 20px 5px; text-transform: uppercase; }
        .topbar { background: #fff; height: 70px; display: flex; align-items: center; padding: 0 25px; box-shadow: 0 1px 2px rgba(0,0,0,0.03); }
        
        /* Styles used across various views */
        .stat-card { border: none; border-radius: 12px; transition: transform 0.2s; background: #fff; }
        .stat-card:hover { transform: translateY(-4px); box-shadow: 0 10px 20px rgba(0,0,0,0.08); }
        .icon-box { width: 45px; height: 45px; display: flex; align-items: center; justify-content: center; border-radius: 8px; font-size: 1.3rem; }
        .bg-soft-primary { background-color: rgba(64, 81, 137, 0.1); color: #405189; }
        .bg-soft-success { background-color: rgba(10, 179, 156, 0.1); color: #0ab39c; }
        .bg-soft-info { background-color: rgba(41, 156, 219, 0.1); color: #299cdb; }
        .bg-soft-warning { background-color: rgba(247, 184, 75, 0.1); color: #f7b84b; }

        media (max-width: 992px) { #sidebar { margin-left: -250px; } #content { margin-left: 0; } }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<div class="wrapper">
    <nav id="sidebar">
        <div class="p-4 text-center">
            <h4 class="text-white fw-bold">VELZON</h4>
        </div>
        <div class="nav-title">Menu</div>
        <a asp-controller="Home" asp-action="Index" class="nav-link"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
        
        <div class="nav-title">Management</div>
        <a asp-controller="Category" asp-action="Index" class=""><i class="bi bi-tags me-2"></i> Categories</a>
        <a asp-controller="Movie" asp-action="Index" class="nav-link"><i class="bi bi-film me-2"></i> Movies</a>
        <a asp-controller="Actor" asp-action="Index" class="nav-link"><i class="bi bi-people me-2"></i> Actors</a>
        <a asp-controller="Cinema" asp-action="Index" class="nav-link"><i class="bi bi-building me-2"></i> Cinemas</a>
    </nav>
    <div id="content">
        <header class="topbar d-flex justify-content-between">
            <div class="d-flex align-items-center">
                <i class="bi bi-list fs-4 me-3" style="cursor:pointer"></i>
                <div class="input-group d-none d-md-flex" style="width: 250px;">
                    <span class="input-group-text bg-light border-0"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control bg-light border-0" placeholder="Search...">
                </div>
            </div>
            <div class="d-flex align-items-center gap-3">
                <i class="bi bi-bell fs-5"></i>
                <img src="https://ui-avatars.com/api/?name=Admin+User" class="rounded-circle" width="35">
            </div>
        </header>
        <main role="main" class="container-fluid p-4">
            @RenderBody()
        </main>
    </div>
    </div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>