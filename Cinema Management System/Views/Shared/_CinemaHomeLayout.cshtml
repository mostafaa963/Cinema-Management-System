@using Cinema_Management_System.DataAccess
@using Microsoft.AspNetCore.Identity
@* @using Cinema_Management_System.Models *@
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Metro Cinema</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { background-color: #0c0f12; color: #f8f9fa; font-family: 'Poppins', sans-serif; overflow-x: hidden; }
        .navbar-cinema { background-color: #161a1e; border-bottom: 1px solid #232931; }
        .footer-cinema { background-color: #161a1e; border-top: 1px solid #232931; color: #6c757d; }
        .dropdown-menu { background-color: #161a1e; border: 1px solid #232931; }
        .dropdown-item { color: #adb5bd; }
        .dropdown-item:hover { background-color: #232931; color: #ffc107; }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark navbar-cinema sticky-top shadow-sm">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-bold text-warning" href="/">⚡ METRO CINEMA</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link" href="/Movies">Now Showing</a></li>
                </ul>

                <ul class="navbar-nav ms-auto">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <!-- Logged In Menu -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-warning" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle"></i> @User.Identity?.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow">
                                <li><a class="dropdown-item" href="/Identity/Profile/Index"><i class="bi bi-gear me-2"></i> Profile</a></li>
                                <li><a class="dropdown-item" href="/Cart"><i class="bi bi-ticket-perforated me-2"></i> My Tickets</a></li>
                                <li><hr class="dropdown-divider border-secondary"></li>
                                <li>
                                    <!-- Logout must be a POST form for security -->
                                    <form asp-area ="Identity" asp-controller ="Account"  asp-action="Logout">
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right me-2"></i> Logout
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <!-- Guest Menu -->
                        <li class="nav-item"><a class="nav-link" href="/Identity/Account/Login">Login</a></li>
                        <li class="nav-item"><a class="nav-link btn btn-outline-warning btn-sm ms-lg-2" href="/Identity/Account/Register">Sign Up</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    <footer class="footer-cinema text-center py-3 mt-5">
        <div class="container">
            <small>&copy; 2026 - Metro Cinema Management System</small>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>