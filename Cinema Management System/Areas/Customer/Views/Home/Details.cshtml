@model Movie

@{
    ViewData["Title"] = $"{Model.Name} - Details";
}

<div class="container mt-5">
    <div class="card shadow-sm border-0 overflow-hidden">
        <div class="row g-0">
            
            <div class="col-lg-4 bg-light d-flex align-items-center justify-content-center border-end">
                @if (!string.IsNullOrEmpty(Model.MainImg))
                {
                    <img src="@Model.MainImg" class="img-fluid w-100 h-100 object-fit-cover" alt="@Model.Name Poster" style="min-height: 400px;" />
                }
                else
                {
                    <div class="text-muted p-5 text-center">
                        <i class="bi bi-film display-1 d-block mb-3 text-black-50"></i>
                        <span class="fw-semibold">No Image Available</span>
                    </div>
                }
            </div>

            <div class="col-lg-8 d-flex flex-column justify-content-between">
                <div class="card-body p-4 p-md-5">
                    
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                        <h1 class="card-title h2 mb-0 fw-bold text-dark">@Model.Name</h1>
                        <span class="badge @(Model.Status ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger") border px-3 py-2 fs-6 rounded-pill">
                            @(Model.Status ? "Available" : "Unavailable")
                        </span>
                    </div>

                    <p class="text-muted small mb-4">
                        <i class="bi bi-calendar3 me-1"></i> Release Date: @Model.Date.ToString("MMMM dd, yyyy")
                    </p>

                    <div class="mb-4">
                        <h5 class="fw-bold text-secondary">Synopsis</h5>
                        <p class="text-secondary lh-base">
                            @(string.IsNullOrEmpty(Model.Description) ? "No description provided for this movie." : Model.Description)
                        </p>
                    </div>

                    <hr class="text-muted opacity-25 my-4" />

                    @if (Model.Status)
                    {
                        <div class="bg-light rounded-3 p-4 border border-light-subtle mb-4">
                            <h5 class="fw-bold text-dark mb-3"><i class="bi bi-ticket-perforated me-2 text-primary"></i>Book Tickets</h5>
                            
                            <form asp-area="Customer" asp-controller="Cart" asp-action="AddTocCart" method="post" class="row g-3 align-items-end">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@Model.Id" />

                                <div class="col-sm-6">
                                    <label for="ticketQty" class="form-label fw-semibold text-muted small">Select Quantity</label>
                                    <div class="input-group">
                                        <button class="btn btn-outline-secondary" type="button" onclick="adjustQty(-1)">-</button>
                                        <input type="number" id="ticketQty" name="Quantity" class="form-control text-center fw-bold" value="1" min="1" max="10" readonly />
                                        <button class="btn btn-outline-secondary" type="button" onclick="adjustQty(1)">+</button>
                                    </div>
                                </div>

                                <div class="col-sm-6 text-sm-end">
                                    <div class="mb-1 text-muted small">Total Price:</div>
                                    <div class="fs-4 fw-bold text-primary" id="totalPriceDisplay" data-unit-price="@Model.Price">
                                        @Model.Price.ToString("C")
                                    </div>
                                </div>

                                <div class="col-12 mt-3">
                                    <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow-sm">
                                        <i class="bi bi-cart-plus-fill me-2"></i> Add To Cart
                                    </button>
                                </div>
                            </form>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning d-flex align-items-center" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <div>Tickets are currently unavailable for this show.</div>
                        </div>
                    }

                    <div class="d-flex gap-2 justify-content-start border-top pt-4">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning px-4 fw-semibold">
                            <i class="bi bi-pencil-square me-1"></i> Edit Movie
                        </a>
                        <a asp-action="Index" class="btn btn-link text-secondary px-0 ms-auto text-decoration-none">
                            <i class="bi bi-arrow-left me-1"></i> Back to List
                        </a>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Combined quantity adjuster with Dynamic Live Price calculation
        function adjustQty(amount) {
            const qtyInput = document.getElementById('ticketQty');
            const priceDisplay = document.getElementById('totalPriceDisplay');
            const unitPrice = parseFloat(priceDisplay.getAttribute('data-unit-price'));
            
            let currentVal = parseInt(qtyInput.value) || 1;
            let newVal = currentVal + amount;
            
            // Constrain between min (1) and max (10)
            if (newVal >= 1 && newVal <= 10) {
                qtyInput.value = newVal;
                
                // Update total price display dynamically on the client side
                const totalPrice = unitPrice * newVal;
                priceDisplay.innerText = totalPrice.toLocaleString(undefined, { style: 'currency', currency: 'USD' });
                // Note: Change 'USD' to your app's standard currency code if needed
            }
        }
    </script>
}