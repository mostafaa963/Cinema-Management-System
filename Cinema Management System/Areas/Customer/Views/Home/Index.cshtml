@model IEnumerable<Movie>
@{
    ViewData["Title"] = "Cinema Home - Static Preview";
}


<style>
    body {
        background-color: #121212;
        color: #f8f9fa;
    }
    .movie-card {
        background-color: #1c1c1e;
        border: 1px solid #2c2c2e;
        transition: transform 0.2s ease;
    }
    .movie-card:hover {
        transform: translateY(-5px);
    }
    .screen-banner {
        background: linear-gradient(to bottom, #ffffff 0%, #333333 100%);
        box-shadow: 0px 4px 20px rgba(255, 255, 255, 0.2);
        color: #121212;
        font-weight: 800;
        letter-spacing: 4px;
    }
    .seat-grid {
        display: grid;
        grid-template-columns: repeat(8, 1fr);
        gap: 8px;
        max-width: 480px;
        margin: 0 auto;
    }
    .legend-box {
        width: 15px;
        height: 15px;
        display: inline-block;
        border-radius: 3px;
    }
</style>

<div class="container my-5">
    <div class="text-center mb-5">
        <h1 class="text-uppercase fw-bold text-warning tracking-wider">Metropolis Cinema</h1>
        <p class="text-muted">Select a movie, showtime, and your preferred seating</p>
    </div>

    <h3 class="text-white border-bottom border-secondary pb-2 mb-4">Now Showing</h3>
    <div class="row mb-5">
        @foreach (var item in Model)
        {
            <div class="col-xl-4 col-md-6 mb-4">
                <div class="card movie-card h-100 text-white shadow">
                    <div class="row g-0 h-100">
                        <div class="col-4">

                            <img src="~/images/admin_layout/@item.MainImg" class="img-fluid rounded-start h-100 w-100" style="object-fit: cover;" alt="Movie Poster">
                        </div>
                        <div class="col-8">
                            <div class="card-body d-flex flex-column h-100">
                                <h5 class="card-title text-warning fw-bold mb-1">@item.Name</h5>
                                <span class="badge bg-secondary align-self-start mb-3">@item.Home.HomeName</span>

                                <div class="mt-auto">
                                    <p class="mb-2 small text-muted text-uppercase fw-bold">Showtimes:</p>
                                    <div class="d-flex gap-2 flex-wrap">
                                        <a class = "btn btn-outline-warning btn-sm time-btn" href="Customer/Home/Details/@item.Id">Details</a>
                                        <button class="btn btn-outline-warning btn-sm time-btn">13:00</button>
                                        <button class="btn btn-outline-warning btn-sm time-btn">16:30</button>
                                        <button class="btn btn-outline-warning btn-sm time-btn">20:00</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8 p-4 rounded text-center shadow" style="background-color: #1c1c1e; border: 1px solid #2c2c2e;">
            <h4 class="mb-4 text-white fw-bold">Seat Selection</h4>

            <div class="w-70 mx-auto screen-banner py-1 rounded mb-5 small text-center text-uppercase">
                Screen This Way
            </div>

            <div class="seat-grid mb-4">
                <button class="btn btn-outline-success btn-sm static-seat-btn" data-seat="A1">A1</button>
                <button class="btn btn-outline-success btn-sm static-seat-btn" data-seat="A2">A2</button>
                <button class="btn btn-danger btn-sm disabled" disabled>A3</button>
                <button class="btn btn-danger btn-sm disabled" disabled>A4</button>
                <button class="btn btn-outline-success btn-sm static-seat-btn" data-seat="A5">A5</button>
                <button class="btn btn-outline-success btn-sm static-seat-btn" data-seat="A6">A6</button>
                <button class="btn btn-outline-success btn-sm static-seat-btn" data-seat="A7">A7</button>
                <button class="btn btn-outline-success btn-sm static-seat-btn" data-seat="A8">A8</button>

                <button class="btn btn-outline-success btn-sm static-seat-btn" data-seat="B1">B1</button>
                <button class="btn btn-outline-success btn-sm static-seat-btn" data-seat="B2">B2</button>
                <button class="btn btn-outline-success btn-sm static-seat-btn" data-seat="B3">B3</button>
                <button class="btn btn-danger btn-sm disabled" disabled>B4</button>
                <button class="btn btn-danger btn-sm disabled" disabled>B5</button>
                <button class="btn btn-outline-success btn-sm static-seat-btn" data-seat="B6">B6</button>
                <button class="btn btn-outline-success btn-sm static-seat-btn" data-seat="B7">B7</button>
                <button class="btn btn-outline-success btn-sm static-seat-btn" data-seat="B8">B8</button>

                <button class="btn btn-outline-success btn-sm static-seat-btn" data-seat="C1">C1</button>
                <button class="btn btn-outline-success btn-sm static-seat-btn" data-seat="C2">C2</button>
                <button class="btn btn-outline-success btn-sm static-seat-btn" data-seat="C3">C3</button>
                <button class="btn btn-outline-success btn-sm static-seat-btn" data-seat="C4">C4</button>
                <button class="btn btn-outline-success btn-sm static-seat-btn" data-seat="C5">C5</button>
                <button class="btn btn-outline-success btn-sm static-seat-btn" data-seat="C6">C6</button>
                <button class="btn btn-outline-success btn-sm static-seat-btn" data-seat="C7">C7</button>
                <button class="btn btn-outline-success btn-sm static-seat-btn" data-seat="C8">C8</button>
            </div>

            <div class="d-flex justify-content-center gap-4 text-muted small mb-4">
                <div><span class="legend-box bg-dark border border-success me-1"></span> Available</div>
                <div><span class="legend-box bg-success me-1"></span> Selected</div>
                <div><span class="legend-box bg-danger me-1"></span> Sold Out</div>
            </div>

            <div class="border-top border-secondary pt-3 mt-3 text-start px-3">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-0 text-muted small">Selected Seats:</p>
                        <h5 id="selectedSeatsDisplay" class="text-warning mb-0">-</h5>
                    </div>
                    <button id="bookBtn" class="btn btn-warning disabled px-4 fw-bold">Proceed to Payment</button>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const timeButtons = document.querySelectorAll('.time-btn');
            const seatButtons = document.querySelectorAll('.static-seat-btn');
            const displaySeats = document.getElementById('selectedSeatsDisplay');
            const bookBtn = document.getElementById('bookBtn');
            let selectedSeatsList = [];

            // 1. Time Select Handler
            timeButtons.forEach(btn => {
                btn.addEventListener('click', function() {
                    // Reset all other times in the UI
                    timeButtons.forEach(b => b.classList.remove('btn-warning', 'text-dark'));
                    // Highlight active
                    this.classList.add('btn-warning', 'text-dark');
                });
            });

            // 2. Seat Click Handler
            seatButtons.forEach(btn => {
                btn.addEventListener('click', function () {
                    const seatId = this.getAttribute('data-seat');

                    if (this.classList.contains('btn-success')) {
                        // Deselect Seat UI State
                        this.classList.remove('btn-success', 'text-white');
                        this.classList.add('btn-outline-success');
                        selectedSeatsList = selectedSeatsList.filter(item => item !== seatId);
                    } else {
                        // Select Seat UI State
                        this.classList.remove('btn-outline-success');
                        this.classList.add('btn-success', 'text-white');
                        selectedSeatsList.push(seatId);
                    }

                    // Update UI Output Text string
                    if (selectedSeatsList.length > 0) {
                        displaySeats.textContent = selectedSeatsList.join(', ');
                        bookBtn.classList.remove('disabled');
                    } else {
                        displaySeats.textContent = "-";
                        bookBtn.classList.add('disabled');
                    }
                });
            });

            // 3. Form submission mock action
            bookBtn.addEventListener('click', function() {
                alert(`Static Frontend Demo Success!\nSeats Reserved: ${selectedSeatsList.join(', ')}`);
            });
        });
    </script>
}