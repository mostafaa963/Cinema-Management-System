@{
    ViewData["Title"] = "Access Denied";
}

<div class="container text-center" style="margin-top: 10%;">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <!-- Optional: A lock icon to visually represent the restriction -->
            <div class="mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="currentColor" class="bi bi-shield-lock-fill text-danger" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M8 0c-.69 0-1.843.265-2.928.56-1.11.3-2.229.655-2.887.87a1.54 1.54 0 0 0-1.044 1.262c-.596 4.477.787 7.795 2.465 9.99a11.8 11.8 0 0 0 2.517 2.453c.386.273.744.482 1.048.625.28.132.581.24.829.24s.548-.108.829-.24a7 7 0 0 0 1.048-.625 11.8 11.8 0 0 0 2.517-2.453c1.678-2.195 3.061-5.513 2.465-9.99a1.54 1.54 0 0 0-1.044-1.263 63 63 0 0 0-2.887-.87C9.843.266 8.69 0 8 0m0 5a1.5 1.5 0 0 1 .5 2.915V10a.5.5 0 0 1-1 0V7.915A1.5 1.5 0 0 1 8 5" />
                </svg>
            </div>
            
            <h1 class="text-danger display-4 fw-bold">403</h1>
            <h2 class="mb-3">Access Denied</h2>
            <p class="text-muted mb-4">
                Oops! You don't have permission to access this page.
                Please contact your administrator if you think this is a mistake.
            </p>
            
            <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg px-4 gap-3">
                    Go to Home
                </a>
                <button onclick="history.back()" class="btn btn-outline-secondary btn-lg px-4">
                    Go Back
                </button>
            </div>
        </div>
    </div>
</div>
