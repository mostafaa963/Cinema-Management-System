@model Actor
@section Scripts{
 <partial name="_ValidationScriptsPartial">
}
<div class="container-fluid px-4">
    <h1 class="mt-4">Actor Management</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a href="/Admin/Home">Dashboard</a></li>
        <li class="breadcrumb-item"><a href="/Admin/Actor">Actors</a></li>
        <li class="breadcrumb-item active">@(Model.ID == 0 ? "Create" : "Edit") Actor</li>
    </ol>

    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-dark text-white d-flex align-items-center justify-content-between">
                    <div class="fw-bold">
                        <i class="fas fa-user-edit me-1"></i> 
                        @(Model.ID == 0 ? "Add New Actor" : "Modify Actor Details")
                    </div>
                    <a href="/Admin/Actor" class="btn btn-sm btn-outline-light">
                        <i class="fas fa-arrow-left me-1"></i> Back to List
                    </a>
                </div>
                <div class="card-body p-4">
                    <form method="post" enctype="multipart/form-data">
                        <input type="hidden" name="ID" value="@Model.ID">

                        <div class="row">
                            <div class="col-md-8">
                                <div class="row g-3">
                                    <div class="col-12">
                                        <label for="Name" class="form-label fw-bold">Full Name</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light"><i class="fas fa-user"></i></span>
                                            <input type="text" class="form-control" id="Name" asp-for="@Model.Name"
                                                   placeholder="e.g. Robert Downey Jr." required>
                                        </div>
                                            <span asp-validation-for="@Model.Name" class="text-danger"></span>
                                    </div>

                                    <div class="col-md-6">
                                        <label for="Nationality" class="form-label fw-bold">Nationality</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light"><i class="fas fa-globe"></i></span>
                                            <input type="text" class="form-control" id="Nationality"  
                                                   placeholder="e.g. American" asp-for="@Model.Nationality">
                                        </div>
                                             <span asp-validation-for="@Model.Nationality" class="text-danger"></span>
                                    </div>

                                    <div class="col-md-6">
                                        <label for="MovieID" class="form-label fw-bold">Movie Number</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light"><i class="fas fa-film"></i></span>
                                            <input type="number" class="form-control" id="MovieID" name="MovieID" 
                                                   value="@Model.MovieID">
                                                    
                                        </div>
                                    </div>

                                    @* <div class="col-12 mt-3">
                                        <div class="form-check form-switch custom-switch">
                                            <input class="form-check-input" type="checkbox" id="Status" name="Status" 
                                                   value="true" @(Model.Status ? "checked" : "")>
                                            <label class="form-check-label fw-bold" for="Status">Active Status</label>
                                        </div>
                                        <small class="text-muted">Set to inactive to hide this actor from public listings.</small>
                                    </div> *@
                                </div>
                            </div>

                            <div class="col-md-4 border-start text-center"
                                <label class="form-label fw-bold d-block">Profile Picture</label>
                                <div class="mb-3">
                                    
                                    <img src="~/images/admin_layout/@Model.Image" 
                                         class="rounded-circle img-thumbnail shadow-sm mb-2" alt="Profile" style="width: 150px; height: 150px; object-fit: cover;">
                                </div>
                                <div class="px-3">
                                    <input type="file" class="form-control form-control-sm" name="logo">
                                </div>
                            </div>
                        </div>

                        <hr class="my-4" />

                        <div class="d-flex justify-content-end gap-2">
                            <button type="reset" class="btn btn-light border px-4">
                                <i class="fas fa-undo me-1"></i> Clear
                            </button>
                            <button type="submit" class="btn btn-primary px-5 shadow-sm">
                                <i class="fas fa-save me-1"></i> Save Actor
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card { border-radius: 10px; }
    .card-header { border-radius: 10px 10px 0 0 !important; }
    .input-group-text { border-right: 0; }
    .input-group .form-control { border-left: 0; }
    .input-group .form-control:focus { border-color: #dee2e6; box-shadow: none; }
    .custom-switch .form-check-input { width: 2.5em; height: 1.25em; cursor: pointer; }
</style>