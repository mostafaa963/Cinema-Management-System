@model CreateActorViewModel

@section Scripts{
 <partial name="_ValidationScriptsPartial">
}
<div class="container-fluid px-4">
    <h1 class="mt-4">Actor Management</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a href="/Admin/Home">Dashboard</a></li>
        <li class="breadcrumb-item"><a href="/Admin/Actor">Actors</a></li>
        <li class="breadcrumb-item active">Create New</li>
    </ol>
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow border-0 mb-4">
                <div class="card-header bg-dark text-white d-flex align-items-center justify-content-between">
                    <div class="fw-bold"><i class="fas fa-user-plus me-2"></i>Register New Actor</div>
                    <a href="/Admin/Actor" class="btn btn-sm btn-outline-light">
                        <i class="fas fa-arrow-left me-1"></i> Back to List
                    </a>
                </div>
                <div class="card-body p-4">
                    <form method="post" enctype="multipart/form-data">
                        <div class="row">
                            <div class="col-md-4 border-end text-center">
                                <div class="mb-3">
                                    <label class="form-label fw-bold d-block">Profile Preview</label>
                                    <div class="bg-light d-flex align-items-center justify-content-center mx-auto rounded-circle shadow-sm" style="width: 150px; height: 150px; border: 2px dashed #dee2e6;">
                                        <i class="fas fa-user-tie fa-4x text-muted"></i>
                                    </div>
                                </div>
                                <div class="mb-3 px-3">
                                    <input type="file" class="form-control form-control-sm" name="logo" id="ProfilePicture">
                                    <div class="form-text small">Upload JPG or PNG (Max 2MB)</div>
                                    @* <span asp-validation-for="@Model.Actor.Image" class="text-danger"></span> *@
                                </div>
                            </div>

                            <div class="col-md-8">
                                <div class="row g-3">
                                    <div class="col-md-12">
                                        <label for="Name" class="form-label fw-bold">Full Name</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-white"><i class="fas fa-id-card text-primary"></i></span>
                                            <input type="text" class="form-control" id="Name"asp-for="@Model.Actor.Name" placeholder="e.g. Leonardo DiCaprio" required>
                                            <span asp-validation-for="@Model.Actor.Name" class="text-danger"></span>

                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <label for="Nationality" class="form-label fw-bold">Nationality</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-white"><i class="fas fa-globe-americas text-success"></i></span>
                                            <input type="text" class="form-control" id="Nationality"asp-for="@Model.Actor.Nationality" placeholder="e.g. British">
                                        <span asp-validation-for="@Model.Actor.Nationality" class="text-danger"></span>
                                        </div>
                                    </div>

                                     <div class="col-md-6">
                                        <label for="CinemaId" class="form-label fw-bold">Movies</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-white"><i class="fas fa-building text-info"></i></span>
                                            <select class="form-select" id="MovieID" name="MovieID" required>
                                                <option value="">Select Movies...</option>
                                                @foreach(var movie in Model.Movies) {
                                                    <option value="@movie.Id">@movie.Name</option>
                                                }
                                            </select>
                                        </div>
                                    </div>

                                    <div class="col-12 mt-4">
                                        <div class="form-check form-switch custom-switch">
                                            <input class="form-check-input" type="checkbox" id="Status" name="Status" value="true" checked>
                                            <label class="form-check-label fw-bold" for="Status">Active Status</label>
                                        </div>
                                        <small class="text-muted">Inactive actors will not appear in public search results.</small>
                                    </div>
                                </div>
                            </div>
                        </div

                        <hr class="my-4" />

                        <div class="d-flex justify-content-end gap-2">
                            <button type="reset" class="btn btn-light border px-4">Reset</button>
                            <button type="submit" class="btn btn-primary px-5 shadow">
                                <i class="fas fa-save me-1"></i> Save Actor
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Styling for the form enhancements */
    .card { border-radius: 15px; }
    .card-header { border-radius: 15px 15px 0 0 !important; }
    .input-group-text { border-right: 0; color: #495057; }
    .input-group .form-control { border-left: 0; }
    .input-group .form-control:focus { border-color: #ced4da; box-shadow: none; }
    .custom-switch .form-check-input { width: 3em; height: 1.5em; cursor: pointer; }
</style>