@model Category

<div class="container">
    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h2 class="display-6">Create new Category</h2>
        </div>
    </div>

    <div class="row my-3">
        <div class="col-12">
            <form method="post">
                <div class="mb-3">
                    <label for="Name" class="form-label">Name</label>
                    <input class="form-control" placeholder="Name" name="HomeName" value="@Model.HomeName">
                </div>
                <div class="mb-3">
                    <input type="hidden" class="form-control" name="ID" value="@Model.ID">
                </div>
                <div class="mb-3">
                    <div class="form-floating">
                        <textarea class="form-control" style="height: 100px" placeholder="Leave a Description here" id="Description" name="Description">@Model.Description</textarea>
                        <label for="Description">Description</label>
                    </div>
                </div>
                @* <div class="mb-3">
                    <label for="Status" class="form-label">Status</label>
                    <select name="Status" class="form-select" id="Status">
                        @if (Model.Status)
                        {
                            <option value="true" selected>Active</option>
                            <option value="false">In Active</option>
                        }
                        else
                        {
                            <option value="true">Active</option>
                            <option value="false" selected>In Active</option>
                        }
                    </select> *@

                @* <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="checkDefault" name="Status" value="true">
                        <label class="form-check-label" for="checkDefault">
                            Active / In Active
                        </label>
                    </div>  *@
            <button type="submit" class="btn btn-primary">Submit</button>
        </form>
    </div>
</div>